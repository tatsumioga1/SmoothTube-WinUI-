<Page
    x:Class="SmoothTube.ChannelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models"
    xmlns:controls="using:SmoothTube.Controls">

    <ScrollViewer>

        <StackPanel
            Padding="40,24,40,24"
            Spacing="24">

            <Button
                Content="Back"
                HorizontalAlignment="Left"
                Click="BackButton_Click"/>

            <Border
                x:Name="ChannelBanner"
                Height="240"
                MinHeight="200"
                MaxHeight="280"
                CornerRadius="14"
                Background="#1F1F1F">

                <Grid>

                <Image
                    x:Name="ChannelBannerImage"
                    Stretch="UniformToFill"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                    <TextBlock
                        x:Name="ChannelBannerPlaceholder"
                        Text="{x:Bind Channel.Title}"
                        FontSize="34"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.45"/>

                </Grid>

            </Border>

            <Grid ColumnSpacing="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border
                    Width="88"
                    Height="88"
                    CornerRadius="44"
                    Background="#1F1F1F">

                    <Image
                        x:Name="ChannelThumbnailImage"
                        Stretch="UniformToFill"/>

                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="6">

                    <TextBlock
                        Text="{x:Bind Channel.Title}"
                        FontSize="36"
                        FontWeight="Bold"/>

                    <TextBlock
                        Text="{x:Bind ChannelSubscriberText, Mode=OneWay}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Opacity="0.72"
                        Visibility="{x:Bind ChannelSubscriberVisibility, Mode=OneWay}"/>

                    <TextBlock
                        Text="{x:Bind Channel.Description}"
                        TextWrapping="Wrap"
                        MaxLines="2"
                        Opacity="0.75"/>

                </StackPanel>

                <Button
                    x:Name="SubscribeButton"
                    Grid.Column="2"
                    Content="Subscribe"
                    VerticalAlignment="Center"
                    Click="SubscribeButton_Click"/>

            </Grid>

            <StackPanel Spacing="8">

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="10"
                    Visibility="{x:Bind LoadingVisibility, Mode=OneWay}">

                    <ProgressRing
                        Width="18"
                        Height="18"
                        IsActive="True"/>

                    <TextBlock
                        Text="{x:Bind LoadingText, Mode=OneWay}"
                        VerticalAlignment="Center"
                        Opacity="0.85"/>

                </StackPanel>

                <TextBlock
                    Text="{x:Bind StatusText, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Opacity="0.75"/>

            </StackPanel>

            <Pivot
                x:Name="ChannelContentPivot"
                SelectionChanged="ChannelContentPivot_SelectionChanged">

                <PivotItem Header="Uploads">

            <ItemsControl
                Margin="0,16,0,0"
                ItemsSource="{x:Bind UploadVideos}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="260"
                            ItemHeight="255"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate x:DataType="local:VideoItem">

                        <Border
                            Margin="0,0,20,20"
                            Tapped="VideoCard_Tapped">

                                    <controls:VideoCardControl
                                        CardWidth="240"
                                        CardHeight="235"
                                        ThumbnailHeight="135"
                                        ThumbnailStretch="Uniform"
                                        Title="{x:Bind Title}"
                                        Channel="{x:Bind Channel}"
                                        Views="{x:Bind Views}"
                                        Duration="{x:Bind Duration}"
                                        IsLive="{x:Bind IsLive}"
                                        IsPremiere="{x:Bind IsPremiere}"
                                        Thumbnail="{x:Bind Thumbnail}"
                                        ShowProgress="False"/>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

                </PivotItem>

                <PivotItem Header="Shorts">

            <ItemsControl
                Margin="0,16,0,0"
                ItemsSource="{x:Bind ShortVideos}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="260"
                            ItemHeight="255"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate x:DataType="local:VideoItem">

                        <Border
                            Margin="0,0,20,20"
                            Tapped="VideoCard_Tapped">

                            <controls:VideoCardControl
                                CardWidth="240"
                                CardHeight="235"
                                ThumbnailHeight="135"
                                Title="{x:Bind Title}"
                                Channel="{x:Bind Channel}"
                                Views="{x:Bind Views}"
                                Duration="{x:Bind Duration}"
                                IsLive="{x:Bind IsLive}"
                                IsPremiere="{x:Bind IsPremiere}"
                                Thumbnail="{x:Bind Thumbnail}"
                                ShowProgress="False"/>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

                </PivotItem>

                <PivotItem Header="Livestreams">

            <ItemsControl
                Margin="0,16,0,0"
                ItemsSource="{x:Bind LivestreamVideos}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="260"
                            ItemHeight="255"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate x:DataType="local:VideoItem">

                        <Border
                            Margin="0,0,20,20"
                            Tapped="VideoCard_Tapped">

                            <controls:VideoCardControl
                                CardWidth="240"
                                CardHeight="235"
                                ThumbnailHeight="135"
                                Title="{x:Bind Title}"
                                Channel="{x:Bind Channel}"
                                Views="{x:Bind Views}"
                                Duration="{x:Bind Duration}"
                                IsLive="{x:Bind IsLive}"
                                IsPremiere="{x:Bind IsPremiere}"
                                Thumbnail="{x:Bind Thumbnail}"
                                ShowProgress="False"/>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

                </PivotItem>

            </Pivot>

            <Grid>

                <Button
                    Content="Load more"
                    HorizontalAlignment="Center"
                    Click="LoadMoreButton_Click"/>

            </Grid>

        </StackPanel>

    </ScrollViewer>

</Page>
