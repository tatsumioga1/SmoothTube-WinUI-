<UserControl
    x:Class="SmoothTube.Controls.VideoCardControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Width="{Binding CardWidth, ElementName=Root}"
        Height="{Binding CardHeight, ElementName=Root}"
        CornerRadius="16"
        Background="{ThemeResource AppCardBackgroundBrush}"
        PointerEntered="Card_PointerEntered"
        PointerExited="Card_PointerExited">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Thumbnail -->

            <Border
                Grid.Row="0"
                Width="{Binding CardWidth, ElementName=Root}"
                Height="{Binding ThumbnailHeight, ElementName=Root}"
                CornerRadius="16,16,0,0"
                Background="{ThemeResource AppThumbnailBackgroundBrush}">

                <Grid
                    Width="{Binding CardWidth, ElementName=Root}"
                    Height="{Binding ThumbnailHeight, ElementName=Root}">

                    <Image
                        x:Name="ThumbnailImage"
                        ImageFailed="ThumbnailImage_ImageFailed"
                        Width="{Binding CardWidth, ElementName=Root}"
                        Height="{Binding ThumbnailHeight, ElementName=Root}"
                        Stretch="{Binding ThumbnailStretch, ElementName=Root}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">

                        <Image.RenderTransform>
                            <ScaleTransform
                                ScaleX="1"
                                ScaleY="1" />
                        </Image.RenderTransform>

                    </Image>

                    <Border
                        x:Name="DurationBadge"
                        Margin="8"
                        Padding="6,2"
                        CornerRadius="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="{ThemeResource AppBadgeBackgroundBrush}">

                        <TextBlock
                            Text="{Binding Duration, ElementName=Root}"
                            Foreground="{StaticResource AppMediaForegroundBrush}"
                            FontSize="12"
                            FontWeight="SemiBold" />

                    </Border>

                    <Border
                        x:Name="PremiereBadge"
                        Margin="8"
                        Padding="7,3"
                        CornerRadius="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="{ThemeResource AppPremiereBadgeBackgroundBrush}">

                        <TextBlock
                            Text="PREMIERE"
                            Foreground="{StaticResource AppMediaForegroundBrush}"
                            FontSize="11"
                            FontWeight="Bold" />

                    </Border>

                    <Border
                        x:Name="LiveBadge"
                        Margin="8"
                        Padding="7,3"
                        CornerRadius="4"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="{ThemeResource AppLiveBadgeBackgroundBrush}">

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="4">

                            <Ellipse
                                Width="6"
                                Height="6"
                                Fill="White"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Text="LIVE"
                                Foreground="{StaticResource AppMediaForegroundBrush}"
                                FontSize="11"
                                FontWeight="Bold" />

                        </StackPanel>

                    </Border>

                    <ProgressBar
                        x:Name="ProgressBarControl"
                        Margin="8,0,8,4"
                        Height="4"
                        Minimum="0"
                        Maximum="100"
                        VerticalAlignment="Bottom"
                        Value="{Binding Progress, ElementName=Root}" />

                </Grid>

            </Border>

            <!-- Metadata -->

            <StackPanel
                Grid.Row="1"
                Margin="12,10,12,10">

                <Grid ColumnSpacing="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border
                        MinWidth="20"
                        MinHeight="24"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind TitleLeadingEmojiVisibility, Mode=OneWay}">

                        <TextBlock
                            Text="{x:Bind TitleLeadingEmoji, Mode=OneWay}"
                            FontSize="16"
                            FontFamily="Segoe UI Emoji"
                            LineHeight="24"
                            LineStackingStrategy="BlockLineHeight"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"/>

                    </Border>

                    <TextBlock
                        Grid.Column="1"
                        Margin="{x:Bind TitleTextMargin, Mode=OneWay}"
                        Text="{x:Bind TitleDisplayText, Mode=OneWay}"
                        FontSize="16"
                        FontWeight="SemiBold"
                        FontFamily="Segoe UI Variable Text, Segoe UI Emoji, Segoe UI Symbol"
                        LineHeight="21"
                        LineStackingStrategy="BlockLineHeight"
                        TextWrapping="WrapWholeWords"
                        MaxLines="2"/>

                </Grid>

                <TextBlock
                    Margin="0,2,0,0"
                    Text="{Binding Channel, ElementName=Root}"
                    Opacity="0.75"
                    FontSize="13" />

                <TextBlock
                    Text="{Binding Views, ElementName=Root}"
                    Opacity="0.75"
                    FontSize="12" />

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
