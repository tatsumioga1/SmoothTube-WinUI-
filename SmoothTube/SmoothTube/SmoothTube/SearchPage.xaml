<Page
    x:Class="SmoothTube.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models">

    <Grid
        Padding="40"
        RowSpacing="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="Search"
            FontSize="42"
            FontWeight="Bold"/>

        <Grid
            Grid.Row="1"
            ColumnSpacing="12">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SearchBox"
                PlaceholderText="Search videos and channels..."
                IsSpellCheckEnabled="False"
                IsTextPredictionEnabled="False"
                MaxLength="120"
                KeyDown="SearchBox_KeyDown"/>

            <Button
                Grid.Column="1"
                Content="Search"
                Click="SearchButton_Click"/>

            <ProgressRing
                Grid.Column="2"
                Width="32"
                Height="32"
                IsActive="{x:Bind IsSearching}"
                Visibility="{x:Bind LoadingVisibility}"/>

        </Grid>

        <TextBlock
            Grid.Row="2"
            Text="{x:Bind StatusText}"
            TextWrapping="Wrap"
            Opacity="0.75"/>

        <ListView
            Grid.Row="3"
            ItemsSource="{x:Bind Results}"
            SelectionMode="None"
            IsItemClickEnabled="False">

            <ListView.ItemTemplate>

                <DataTemplate x:DataType="local:SearchResultItem">

                    <Border
                        Margin="0,0,0,12"
                        Padding="12"
                        CornerRadius="8"
                        Background="#1F1F1F"
                        Tapped="Result_Tapped">

                        <Grid ColumnSpacing="16">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid
                                Grid.Column="0"
                                Height="124"
                                Visibility="{x:Bind ChannelThumbnailVisibility, Mode=OneTime}">

                                <Ellipse
                                    Width="104"
                                    Height="104"
                                    Fill="#151515"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                                <Ellipse
                                    Width="104"
                                    Height="104"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <Ellipse.Fill>
                                        <ImageBrush
                                            Stretch="UniformToFill"
                                            ImageSource="{x:Bind ThumbnailSource, Mode=OneTime}"/>
                                    </Ellipse.Fill>

                                </Ellipse>

                            </Grid>

                            <Border
                                Grid.Column="0"
                                Height="124"
                                CornerRadius="8"
                                Background="#151515"
                                Visibility="{x:Bind VideoThumbnailVisibility, Mode=OneTime}">

                                <Image
                                    Stretch="UniformToFill"
                                    Source="{x:Bind ThumbnailSource, Mode=OneTime}"/>

                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">

                                <TextBlock
                                    Text="{x:Bind Title}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    TextWrapping="WrapWholeWords"/>

                                <TextBlock
                                    Text="{x:Bind Subtitle}"
                                    Opacity="0.75"/>

                                <TextBlock
                                    Text="{x:Bind Detail}"
                                    TextWrapping="Wrap"
                                    MaxLines="2"
                                    Opacity="0.65"/>

                            </StackPanel>

                        </Grid>

                    </Border>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

    </Grid>

</Page>
