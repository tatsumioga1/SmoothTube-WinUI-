<Page
    x:Class="SmoothTube.SubscriptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models"
    xmlns:controls="using:SmoothTube.Controls">

    <ScrollViewer>

        <StackPanel
            Padding="40,24,40,24"
            Spacing="24">

            <TextBlock
                Text="Subscriptions"
                FontSize="42"
                FontWeight="Bold"/>

            <TextBlock
                Text="{x:Bind StatusText}"
                TextWrapping="Wrap"
                Opacity="0.75"/>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleSwitch
                    x:Name="IncludeShortsSwitch"
                    Header="Include Shorts"
                    IsOn="False"
                    Toggled="Filters_Changed"/>

                <Button
                    Grid.Column="2"
                    Width="40"
                    Height="40"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    ToolTipService.ToolTip="Refresh subscriptions"
                    Click="RefreshButton_Click">

                    <SymbolIcon Symbol="Refresh"/>

                </Button>

            </Grid>

            <TextBlock
                Text="Latest videos"
                FontSize="24"
                FontWeight="SemiBold"/>

            <Pivot
                x:Name="SubscriptionsPivot"
                SelectionChanged="SubscriptionsPivot_SelectionChanged">

                <PivotItem Header="Recent Uploads">

                    <StackPanel
                        Margin="0,20,0,0"
                        Spacing="16">

                        <ItemsControl ItemsSource="{x:Bind Videos}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid
                                        Orientation="Horizontal"
                                        ItemWidth="300"
                                        ItemHeight="285"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>

                                <DataTemplate x:DataType="local:VideoItem">

                                    <Border
                                        Margin="0,0,12,20"
                                        Tapped="VideoCard_Tapped">

                                        <controls:VideoCardControl
                                            CardWidth="280"
                                            CardHeight="265"
                                            ThumbnailHeight="157.5"
                                            Title="{x:Bind Title}"
                                            Channel="{x:Bind Channel}"
                                            Views="{x:Bind Views}"
                                            Duration="{x:Bind Duration}"
                                            IsLive="{x:Bind IsLive}"
                                            IsPremiere="{x:Bind IsPremiere}"
                                            Thumbnail="{x:Bind Thumbnail}"
                                            ShowProgress="False"/>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <Button
                            x:Name="LoadMoreButton"
                            Content="Load more"
                            HorizontalAlignment="Center"
                            Visibility="{x:Bind LoadMoreVisibility}"
                            Click="LoadMoreButton_Click"/>

                    </StackPanel>

                </PivotItem>

                <PivotItem Header="Premieres">

                    <ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{x:Bind PremiereVideos}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid
                                    Orientation="Horizontal"
                                    ItemWidth="300"
                                    ItemHeight="285"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:VideoItem">

                                <Border
                                    Margin="0,0,12,20"
                                    Tapped="VideoCard_Tapped">

                                    <controls:VideoCardControl
                                        CardWidth="280"
                                        CardHeight="265"
                                        ThumbnailHeight="157.5"
                                        Title="{x:Bind Title}"
                                        Channel="{x:Bind Channel}"
                                        Views="{x:Bind Views}"
                                        Duration="{x:Bind Duration}"
                                        IsLive="{x:Bind IsLive}"
                                        IsPremiere="{x:Bind IsPremiere}"
                                        Thumbnail="{x:Bind Thumbnail}"
                                        ShowProgress="False"/>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </PivotItem>

                <PivotItem Header="Livestreams">

                    <ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{x:Bind LivestreamVideos}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid
                                    Orientation="Horizontal"
                                    ItemWidth="300"
                                    ItemHeight="285"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:VideoItem">

                                <Border
                                    Margin="0,0,12,20"
                                    Tapped="VideoCard_Tapped">

                                    <controls:VideoCardControl
                                        CardWidth="280"
                                        CardHeight="265"
                                        ThumbnailHeight="157.5"
                                        Title="{x:Bind Title}"
                                        Channel="{x:Bind Channel}"
                                        Views="{x:Bind Views}"
                                        Duration="{x:Bind Duration}"
                                        IsLive="{x:Bind IsLive}"
                                        IsPremiere="{x:Bind IsPremiere}"
                                        Thumbnail="{x:Bind Thumbnail}"
                                        ShowProgress="False"/>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </PivotItem>

            </Pivot>

        </StackPanel>

    </ScrollViewer>

</Page>
