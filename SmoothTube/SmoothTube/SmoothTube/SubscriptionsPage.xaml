<Page
    x:Class="SmoothTube.SubscriptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models"
    xmlns:controls="using:SmoothTube.Controls">

    <ScrollViewer>

        <StackPanel
            Padding="40,24,40,24"
            Spacing="24">

            <TextBlock
                Text="Subscriptions"
                FontSize="42"
                FontWeight="Bold"/>

            <TextBlock
                Text="{x:Bind StatusText}"
                TextWrapping="Wrap"
                Opacity="0.75"/>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleSwitch
                    x:Name="IncludeShortsSwitch"
                    Header="Include Shorts"
                    IsOn="False"
                    Toggled="Filters_Changed"/>

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="2"
                    Width="40"
                    Height="40"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    ToolTipService.ToolTip="Refresh subscriptions"
                    Click="RefreshButton_Click">

                    <Grid>

                        <SymbolIcon
                            Symbol="Refresh"
                            Visibility="{x:Bind RefreshIconVisibility, Mode=OneWay}"/>

                        <ProgressRing
                            Width="18"
                            Height="18"
                            IsActive="{x:Bind IsRefreshing, Mode=OneWay}"
                            Visibility="{x:Bind RefreshProgressVisibility, Mode=OneWay}"/>

                    </Grid>

                </Button>

            </Grid>

            <TextBlock
                Text="Latest videos"
                FontSize="24"
                FontWeight="SemiBold"/>

            <Grid>

                <Pivot
                    x:Name="SubscriptionsPivot"
                    Visibility="{x:Bind FeedContentVisibility, Mode=OneWay}"
                    SelectionChanged="SubscriptionsPivot_SelectionChanged">

                <PivotItem Header="Recent Uploads">

                    <StackPanel
                        Margin="0,20,0,0"
                        Spacing="16">

                        <ItemsControl ItemsSource="{x:Bind Videos}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid
                                        Orientation="Horizontal"
                                        ItemWidth="300"
                                        ItemHeight="285"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>

                                <DataTemplate x:DataType="local:VideoItem">

                                    <Border
                                        Margin="0,0,12,20"
                                        Tapped="VideoCard_Tapped">

                                        <controls:VideoCardControl
                                            CardWidth="280"
                                            CardHeight="265"
                                            ThumbnailHeight="157.5"
                                            Title="{x:Bind Title}"
                                            Channel="{x:Bind Channel}"
                                            Views="{x:Bind Views}"
                                            Duration="{x:Bind Duration}"
                                            IsLive="{x:Bind IsLive}"
                                            IsPremiere="{x:Bind IsPremiere}"
                                            Thumbnail="{x:Bind Thumbnail}"
                                            ShowProgress="False"/>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                        <Button
                            x:Name="LoadMoreButton"
                            Content="Load more"
                            HorizontalAlignment="Center"
                            Visibility="{x:Bind LoadMoreVisibility}"
                            Click="LoadMoreButton_Click"/>

                    </StackPanel>

                </PivotItem>

                <PivotItem Header="Premieres">

                    <ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{x:Bind PremiereVideos}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid
                                    Orientation="Horizontal"
                                    ItemWidth="300"
                                    ItemHeight="285"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:VideoItem">

                                <Border
                                    Margin="0,0,12,20"
                                    Tapped="VideoCard_Tapped">

                                    <controls:VideoCardControl
                                        CardWidth="280"
                                        CardHeight="265"
                                        ThumbnailHeight="157.5"
                                        Title="{x:Bind Title}"
                                        Channel="{x:Bind Channel}"
                                        Views="{x:Bind Views}"
                                        Duration="{x:Bind Duration}"
                                        IsLive="{x:Bind IsLive}"
                                        IsPremiere="{x:Bind IsPremiere}"
                                        Thumbnail="{x:Bind Thumbnail}"
                                        ShowProgress="False"/>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </PivotItem>

                <PivotItem Header="Livestreams">

                    <ItemsControl
                        Margin="0,20,0,0"
                        ItemsSource="{x:Bind LivestreamVideos}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid
                                    Orientation="Horizontal"
                                    ItemWidth="300"
                                    ItemHeight="285"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:VideoItem">

                                <Border
                                    Margin="0,0,12,20"
                                    Tapped="VideoCard_Tapped">

                                    <controls:VideoCardControl
                                        CardWidth="280"
                                        CardHeight="265"
                                        ThumbnailHeight="157.5"
                                        Title="{x:Bind Title}"
                                        Channel="{x:Bind Channel}"
                                        Views="{x:Bind Views}"
                                        Duration="{x:Bind Duration}"
                                        IsLive="{x:Bind IsLive}"
                                        IsPremiere="{x:Bind IsPremiere}"
                                        Thumbnail="{x:Bind Thumbnail}"
                                        ShowProgress="False"/>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </PivotItem>

            </Pivot>

                <StackPanel
                    x:Name="FeedSkeletonPanel"
                    Margin="0,20,0,0"
                    Spacing="20"
                    Visibility="{x:Bind FeedSkeletonVisibility, Mode=OneWay}">

                    <TextBlock
                        Text="Loading subscription uploads..."
                        FontSize="16"
                        Opacity="0.7"/>

                    <ItemsControl>

                        <ItemsControl.Items>
                            <x:Int32>1</x:Int32>
                            <x:Int32>2</x:Int32>
                            <x:Int32>3</x:Int32>
                            <x:Int32>4</x:Int32>
                            <x:Int32>5</x:Int32>
                            <x:Int32>6</x:Int32>
                            <x:Int32>7</x:Int32>
                            <x:Int32>8</x:Int32>
                        </ItemsControl.Items>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid
                                    Orientation="Horizontal"
                                    ItemWidth="300"
                                    ItemHeight="285"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border
                                    Width="280"
                                    Height="265"
                                    Margin="0,0,12,20"
                                    CornerRadius="12"
                                    Background="{ThemeResource AppSkeletonCardBackgroundBrush}">

                                    <StackPanel Spacing="10">

                                        <Border
                                            Height="157.5"
                                            CornerRadius="12"
                                            Background="{ThemeResource AppSkeletonStrongBackgroundBrush}"/>

                                        <Border
                                            Width="245"
                                            Height="18"
                                            HorizontalAlignment="Left"
                                            CornerRadius="4"
                                            Background="{ThemeResource AppSkeletonStrongBackgroundBrush}"/>

                                        <Border
                                            Width="190"
                                            Height="14"
                                            HorizontalAlignment="Left"
                                            CornerRadius="4"
                                            Background="{ThemeResource AppSkeletonMediumBackgroundBrush}"/>

                                        <Border
                                            Width="120"
                                            Height="12"
                                            HorizontalAlignment="Left"
                                            CornerRadius="4"
                                            Background="{ThemeResource AppSkeletonSubtleBackgroundBrush}"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

            </Grid>

        </StackPanel>

    </ScrollViewer>

</Page>
