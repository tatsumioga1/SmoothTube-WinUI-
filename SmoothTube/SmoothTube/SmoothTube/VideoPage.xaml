<Page
    x:Class="SmoothTube.VideoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models">

    <Grid x:Name="PageRoot">

    <ScrollViewer x:Name="PageScrollViewer">

        <Grid
            x:Name="MainLayoutGrid"
            Padding="40"
            ColumnSpacing="24">

            <!-- Responsive Rows -->

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>

                <ColumnDefinition
                    x:Name="SidebarColumn"
                    Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- MAIN CONTENT -->

            <StackPanel
                x:Name="MainContentPanel"
                Grid.Row="0"
                Grid.Column="0"
                Spacing="24">

                <!-- Back Button -->

                <StackPanel
                    x:Name="VideoActionsPanel"
                    Orientation="Horizontal"
                    Spacing="12">

                    <Button
                        x:Name="BackButton"
                        Content="← Back"
                        Click="BackButton_Click"/>

                    <Button
                        x:Name="OpenOnYouTubeButton"
                        Content="Watch on YouTube"
                        Click="OpenOnYouTube_Click"/>

                </StackPanel>

                <!-- Player -->

                <StackPanel Spacing="0">

                    <Border
                        x:Name="PlayerBorder"
                        CornerRadius="16"
                        Background="#111111">

                        <Grid>

                            <Grid x:Name="MockPlayerGrid">

                                <Image
                                    Source="{Binding Thumbnail}"
                                    Stretch="Uniform"
                                    Opacity="0.5"/>

                                <Button
                                    Width="80"
                                    Height="80"
                                    Content="▶"
                                    FontSize="32"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                            </Grid>

                            <WebView2
                                x:Name="PlayerWebView"
                                Visibility="Collapsed"/>

                            <Border
                                x:Name="BlockedPlayerOverlay"
                                Padding="32"
                                Background="#E6111111"
                                Visibility="Collapsed">

                                <StackPanel
                                    MaxWidth="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="14">

                                    <TextBlock
                                        Text="Playback is disabled on other websites"
                                        FontSize="24"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap"/>

                                    <TextBlock
                                        Text="This video owner does not allow embedded playback. You can open it in a separate in-app YouTube window."
                                        TextWrapping="Wrap"
                                        Opacity="0.8"/>

                                    <Button
                                        Content="Watch on YouTube"
                                        HorizontalAlignment="Left"
                                        Click="OpenOnYouTube_Click"/>

                                </StackPanel>

                            </Border>

                        </Grid>

                    </Border>

                    <!-- Player Controls -->

                    <Border
                        x:Name="MockControlsPanel"
                        Padding="16"
                        CornerRadius="0,0,16,16"
                        Background="#181818">

                        <StackPanel Spacing="12">

                            <ProgressBar
                                Value="42"
                                Maximum="100"
                                Height="4"/>

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Controls -->

                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="12">

                                    <Button Content="▶"/>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Text="{Binding Duration}"/>

                                </StackPanel>

                                <!-- Right Controls -->

                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="12">

                                    <Button Content="🔊"/>

                                    <Button Content="⛶"/>

                                </StackPanel>

                            </Grid>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <!-- Video Info -->

                <StackPanel
                    x:Name="VideoInfoPanel"
                    Spacing="10">

                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="36"
                        FontWeight="Bold"/>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">

                        <Button
                            x:Name="ChannelButton"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ChannelButton_Click">

                            <TextBlock
                                Text="{Binding Channel}"
                                FontSize="20"
                                Opacity="0.85"/>

                        </Button>

                        <TextBlock
                            Text="{Binding PublishedAt}"
                            VerticalAlignment="Center"
                            Opacity="0.7"/>

                        <Button
                            x:Name="SubscribeButton"
                            Content="Subscribe"
                            Click="SubscribeButton_Click"/>

                        <Button
                            x:Name="LikeButton"
                            ToolTipService.ToolTip="Rate this video as liked on your signed-in YouTube account"
                            Click="LikeButton_Click">

                            <SymbolIcon Symbol="Like"/>

                        </Button>

                        <Button
                            x:Name="DislikeButton"
                            ToolTipService.ToolTip="Rate this video as disliked on your signed-in YouTube account"
                            Click="DislikeButton_Click">

                            <SymbolIcon Symbol="Dislike"/>

                        </Button>

                    </StackPanel>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="14">

                        <TextBlock
                            Text="{Binding Views}"
                            Opacity="0.7"/>

                    </StackPanel>

                </StackPanel>

                <!-- Description -->

                <Border
                    x:Name="DescriptionPanel"
                    Padding="20"
                    CornerRadius="12"
                    Background="#1F1F1F">

                    <StackPanel Spacing="10">

                        <TextBlock
                            x:Name="DescriptionTextBlock"
                            Text="{Binding Description}"
                            TextWrapping="Wrap"
                            MaxLines="3"/>

                        <Button
                            x:Name="DescriptionToggleButton"
                            Content="Show more"
                            HorizontalAlignment="Left"
                            Click="DescriptionToggleButton_Click"/>

                    </StackPanel>

                </Border>

                <StackPanel
                    x:Name="CommentsPanel"
                    Margin="0,-12,0,0"
                    Spacing="16">

                    <TextBlock
                        Text="Comments"
                        FontSize="24"
                        FontWeight="SemiBold"/>

                    <TextBlock
                        Text="{x:Bind CommentsStatus}"
                        TextWrapping="Wrap"
                        Opacity="0.75"/>

                    <ItemsControl
                        ItemsSource="{x:Bind Comments}">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:CommentItem">

                                <Border
                                    Margin="0,0,0,12"
                                    Padding="14"
                                    CornerRadius="12"
                                    Background="#1F1F1F">

                                    <StackPanel Spacing="6">

                                        <TextBlock
                                            Text="{x:Bind Author}"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="{x:Bind Text}"
                                            TextWrapping="Wrap"/>

                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="12">

                                            <TextBlock
                                                Text="{x:Bind PublishedAt}"
                                                Opacity="0.65"
                                                FontSize="12"/>

                                            <TextBlock
                                                Text="{x:Bind LikeCount}"
                                                Opacity="0.65"
                                                FontSize="12"/>

                                        </StackPanel>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

                <StackPanel
                    x:Name="InlineLiveChatPanel"
                    Visibility="Collapsed"
                    Spacing="16">

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="12"
                        Height="36">

                        <TextBlock
                            Text="Live chat"
                            FontSize="24"
                            FontWeight="SemiBold"/>

                        <Button
                            Width="36"
                            Height="36"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Refresh live chat"
                            Click="RefreshLiveChat_Click">

                            <SymbolIcon Symbol="Refresh"/>

                        </Button>

                    </StackPanel>

                    <TextBlock
                        x:Name="LiveChatStatusTextBlock"
                        Text="{x:Bind LiveChatStatus}"
                        TextWrapping="Wrap"
                        Opacity="0.75"/>

                    <ItemsControl
                        ItemsSource="{x:Bind LiveChatMessages}">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate x:DataType="local:LiveChatMessageItem">

                                <Border
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    CornerRadius="10"
                                    Background="#1F1F1F">

                                    <StackPanel Spacing="4">

                                        <TextBlock
                                            Text="{x:Bind Author}"
                                            FontWeight="SemiBold"/>

                                        <TextBlock
                                            Text="{x:Bind Message}"
                                            TextWrapping="Wrap"/>

                                        <TextBlock
                                            Text="{x:Bind PublishedAt}"
                                            Opacity="0.65"
                                            FontSize="12"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </StackPanel>

            </StackPanel>

            <!-- RECOMMENDED -->

            <StackPanel
                x:Name="UpNextPanel"
                Grid.Column="1"
                Width="340"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <StackPanel
                    x:Name="LiveChatPanel"
                    Spacing="0"
                    Visibility="Collapsed">

                    <Grid
                        x:Name="LiveChatHeaderGrid"
                        Width="340"
                        Height="{Binding ActualHeight, ElementName=VideoActionsPanel}"
                        HorizontalAlignment="Stretch"
                        ColumnSpacing="12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Live chat"
                            FontSize="24"
                            FontWeight="SemiBold"/>

                        <Button
                            Grid.Column="2"
                            Width="36"
                            Height="36"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Refresh live chat"
                            Click="RefreshLiveChat_Click">

                            <SymbolIcon Symbol="Refresh"/>

                        </Button>

                    </Grid>

                    <TextBlock
                        x:Name="SidebarLiveChatStatusTextBlock"
                        Text="{x:Bind LiveChatStatus}"
                        TextWrapping="Wrap"
                        Opacity="0.75"/>

                        <Border
                            x:Name="LiveChatWebViewFrame"
                            Height="{Binding ActualHeight, ElementName=PlayerBorder}"
                            Margin="0,24,0,0"
                            CornerRadius="12"
                            Background="#111111"
                            Visibility="Collapsed">

                            <WebView2
                            x:Name="LiveChatWebView"/>

                    </Border>

                    <ScrollViewer
                        x:Name="LiveChatMessagesScrollViewer"
                        Margin="0,8,0,0"
                        MaxHeight="{Binding ActualHeight, ElementName=PlayerBorder}">

                        <ItemsControl
                            ItemsSource="{x:Bind LiveChatMessages}">

                            <ItemsControl.ItemTemplate>

                                <DataTemplate x:DataType="local:LiveChatMessageItem">

                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="#1F1F1F">

                                        <StackPanel Spacing="4">

                                            <TextBlock
                                                Text="{x:Bind Author}"
                                                FontWeight="SemiBold"/>

                                            <TextBlock
                                                Text="{x:Bind Message}"
                                                TextWrapping="Wrap"/>

                                            <TextBlock
                                                Text="{x:Bind PublishedAt}"
                                                Opacity="0.65"
                                                FontSize="12"/>

                                        </StackPanel>

                                    </Border>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </StackPanel>

                    <Grid
                        x:Name="UpNextHeaderGrid"
                        Width="340"
                        HorizontalAlignment="Stretch"
                        Margin="0,4,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                        Grid.Column="0"
                        Text="Up next"
                        FontSize="24"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="8">

                            <TextBlock
                                Text="Autoplay"
                                VerticalAlignment="Center"
                                Opacity="0.8"
                                FontSize="13" />

                            <ToggleSwitch
                                x:Name="AutoPlayUpNextSwitch"
                                MinWidth="0"
                                Width="48"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                OffContent=""
                                OnContent="" />

                            <TextBlock
                                Text="Off"
                                VerticalAlignment="Center"
                                Opacity="0.9"
                                FontSize="13" />
                        </StackPanel>

                    </Grid>

                    <ItemsControl
                    ItemsSource="{x:Bind RecommendedVideos}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate
                            x:DataType="local:VideoItem">

                            <Border
                                Margin="0,0,0,12"
                                Padding="8"
                                CornerRadius="12"
                                Background="#1F1F1F"
                                Tapped="UpNextVideo_Tapped">

                                <Grid ColumnSpacing="12">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        CornerRadius="8">

                                        <Image
                                            Loaded="VideoThumbnail_Loaded"
                                            Height="80"
                                            Stretch="UniformToFill"
                                            DataContext="{Binding}"/>

                                    </Border>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="4">

                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            FontWeight="SemiBold"
                                            TextWrapping="WrapWholeWords"
                                            MaxLines="2"/>

                                        <Grid ColumnSpacing="8">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Text="{x:Bind Channel}"
                                                Opacity="0.7"
                                                TextTrimming="CharacterEllipsis"/>

                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{x:Bind Duration}"
                                                Opacity="0.7"
                                                FontSize="12"/>

                                        </Grid>

                                        <TextBlock
                                            Text="{x:Bind Views}"
                                            Opacity="0.6"
                                            FontSize="12"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </Grid>

    </ScrollViewer>

    </Grid>

</Page>
