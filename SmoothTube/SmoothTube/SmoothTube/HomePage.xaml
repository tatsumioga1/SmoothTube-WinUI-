<Page
    x:Class="SmoothTube.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SmoothTube.Models"
    xmlns:controls="using:SmoothTube.Controls">

    <ScrollViewer>

        <StackPanel
            Padding="40,24,40,24"
            Spacing="24">

            <!-- Header -->

            <TextBlock
                Text="Home"
                FontSize="42"
                FontWeight="Bold"/>

            <TextBlock
                Text="{x:Bind StatusText}"
                TextWrapping="Wrap"
                Opacity="0.7"/>

            <TextBlock
                Text="Continue Watching"
                FontSize="22"
                FontWeight="SemiBold"
                Visibility="{x:Bind ContinueWatchingVisibility}"/>

            <ItemsControl
                ItemsSource="{x:Bind ContinueWatchingVideos}"
                Visibility="{x:Bind ContinueWatchingVisibility}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="240"
                            ItemHeight="210"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate x:DataType="local:VideoItem">

                        <Border
                            Margin="0,0,16,16"
                            Tapped="VideoCard_Tapped">

                            <controls:VideoCardControl
                                CardWidth="220"
                                CardHeight="195"
                                ThumbnailHeight="123.75"
                                Title="{x:Bind Title}"
                                Channel="{x:Bind Channel}"
                                Views="{x:Bind Views}"
                                Duration="{x:Bind Duration}"
                                IsLive="{x:Bind IsLive}"
                                IsPremiere="{x:Bind IsPremiere}"
                                Thumbnail="{x:Bind Thumbnail}"
                                Progress="{x:Bind Progress}"/>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <TextBlock
                Text="{x:Bind PrimarySectionTitle}"
                FontSize="28"
                FontWeight="SemiBold"/>

            <ItemsControl
                ItemsSource="{x:Bind SkeletonItems}"
                Visibility="{x:Bind LoadingVisibility}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="320"
                            ItemHeight="285"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Width="300"
                            Height="265"
                            Margin="0,0,20,20"
                            CornerRadius="16"
                            Background="#1F1F1F">

                            <Grid>

                                <StackPanel>

                                    <Border
                                        Height="168.75"
                                        CornerRadius="16,16,0,0"
                                        Background="#292929"/>

                                    <Border
                                        Width="210"
                                        Height="18"
                                        Margin="12,14,12,0"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="#303030"/>

                                    <Border
                                        Width="130"
                                        Height="14"
                                        Margin="12,10,12,0"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="#2A2A2A"/>

                                    <Border
                                        Width="90"
                                        Height="12"
                                        Margin="12,8,12,0"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="#2A2A2A"/>

                                </StackPanel>

                                <ProgressRing
                                    Width="36"
                                    Height="36"
                                    IsActive="True"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

            <ItemsControl
                ItemsSource="{x:Bind Videos}"
                Visibility="{x:Bind VideosVisibility}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid
                            Orientation="Horizontal"
                            ItemWidth="320"
                            ItemHeight="285"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                <DataTemplate x:DataType="local:VideoItem">

                    <Border
                        Margin="0,0,20,20"
                        Tapped="VideoCard_Tapped">

                        <controls:VideoCardControl
                            CardWidth="300"
                            CardHeight="265"
                            ThumbnailHeight="168.75"
                            Title="{x:Bind Title}"
                            Channel="{x:Bind Channel}"
                            Views="{x:Bind Views}"
                            Duration="{x:Bind Duration}"
                            IsLive="{x:Bind IsLive}"
                            IsPremiere="{x:Bind IsPremiere}"
                            Thumbnail="{x:Bind Thumbnail}"
                            Progress="{x:Bind Progress}" />

                    </Border>

                </DataTemplate>

            </ItemsControl.ItemTemplate>

            </ItemsControl>

            <Button
                Content="Load more"
                HorizontalAlignment="Center"
                Visibility="{x:Bind LoadMoreVisibility}"
                Click="LoadMoreButton_Click"/>

        </StackPanel>

    </ScrollViewer>

</Page>
