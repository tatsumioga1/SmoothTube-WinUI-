<Page
    x:Class="SmoothTube.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:SmoothTube.Models"
    xmlns:controls="using:SmoothTube.Controls">

    <ScrollViewer>

        <StackPanel
            Padding="40,24,40,24"
            Spacing="28">

            <Grid ColumnSpacing="16">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">

                    <TextBlock
                        Text="Library"
                        FontSize="42"
                        FontWeight="Bold"/>

                    <TextBlock
                        Text="{x:Bind StatusText, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.75"/>

                </StackPanel>

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="1"
                    Content="Refresh"
                    VerticalAlignment="Bottom"
                    Click="RefreshButton_Click"/>

            </Grid>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ContinueWatchingVisibility, Mode=OneWay}">

                <TextBlock
                    Text="Continue Watching"
                    FontSize="24"
                    FontWeight="SemiBold"/>

                <ItemsControl
                    ItemsSource="{x:Bind ContinueWatchingVideos}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid
                                Orientation="Horizontal"
                                ItemWidth="280"
                                ItemHeight="265"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:VideoItem">

                            <Border
                                Margin="0,0,18,18"
                                Tapped="VideoCard_Tapped">

                                <controls:VideoCardControl
                                    CardWidth="260"
                                    CardHeight="245"
                                    ThumbnailHeight="146.25"
                                    Title="{x:Bind Title}"
                                    Channel="{x:Bind Channel}"
                                    Views="{x:Bind Views}"
                                    Duration="{x:Bind Duration}"
                                    Progress="{x:Bind Progress}"
                                    IsLive="{x:Bind IsLive}"
                                    IsPremiere="{x:Bind IsPremiere}"
                                    Thumbnail="{x:Bind Thumbnail}"
                                    ShowProgress="True"/>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

            <StackPanel
                Spacing="18"
                Visibility="{x:Bind LoadingVisibility, Mode=OneWay}">

                <ProgressRing
                    Width="36"
                    Height="36"
                    IsActive="{x:Bind IsLoading, Mode=OneWay}"/>

                <TextBlock
                    Text="Loading your YouTube playlists..."
                    Opacity="0.75"/>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind PlaylistsVisibility, Mode=OneWay}">

                <TextBlock
                    Text="Your Playlists"
                    FontSize="24"
                    FontWeight="SemiBold"/>

                <TextBlock
                    Text="{x:Bind EmptyPlaylistsText, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Opacity="0.65"
                    Visibility="{x:Bind EmptyPlaylistsVisibility, Mode=OneWay}"/>

                <ItemsControl
                    ItemsSource="{x:Bind Playlists}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid
                                Orientation="Horizontal"
                                ItemWidth="280"
                                ItemHeight="210"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PlaylistItem">

                            <Border
                                Width="260"
                                Height="190"
                                Margin="0,0,18,18"
                                CornerRadius="16"
                                Background="#1F1F1F"
                                Tapped="PlaylistCard_Tapped">

                                <Grid>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border
                                        Grid.Row="0"
                                        CornerRadius="16,16,0,0"
                                        Background="#111111">

                                        <Grid>

                                            <Image
                                                Source="{x:Bind Thumbnail}"
                                                Stretch="UniformToFill"/>

                                            <Border
                                                Padding="10,6"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="#CC000000"
                                                CornerRadius="8,0,0,0">

                                                <TextBlock
                                                    Text="{x:Bind VideoCountText}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"/>

                                            </Border>

                                        </Grid>

                                    </Border>

                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="12,10,12,10"
                                        Spacing="4">

                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            TextWrapping="WrapWholeWords"
                                            TextTrimming="CharacterEllipsis"
                                            MaxLines="2"/>

                                        <TextBlock
                                            Text="{x:Bind PrivacyStatus}"
                                            FontSize="12"
                                            Opacity="0.65"
                                            TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind PlaylistVideosVisibility, Mode=OneWay}">

                <Grid ColumnSpacing="16">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Text="{x:Bind SelectedPlaylistTitle, Mode=OneWay}"
                        FontSize="24"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis"/>

                    <ProgressRing
                        Grid.Column="1"
                        Width="24"
                        Height="24"
                        IsActive="{x:Bind IsLoadingPlaylistVideos, Mode=OneWay}"
                        Visibility="{x:Bind PlaylistVideosLoadingVisibility, Mode=OneWay}"/>

                </Grid>

                <ItemsControl
                    ItemsSource="{x:Bind PlaylistVideos}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid
                                Orientation="Horizontal"
                                ItemWidth="280"
                                ItemHeight="265"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:VideoItem">

                            <Border
                                Margin="0,0,18,18"
                                Tapped="VideoCard_Tapped">

                                <controls:VideoCardControl
                                    CardWidth="260"
                                    CardHeight="245"
                                    ThumbnailHeight="146.25"
                                    Title="{x:Bind Title}"
                                    Channel="{x:Bind Channel}"
                                    Views="{x:Bind Views}"
                                    Duration="{x:Bind Duration}"
                                    IsLive="{x:Bind IsLive}"
                                    IsPremiere="{x:Bind IsPremiere}"
                                    Thumbnail="{x:Bind Thumbnail}"
                                    ShowProgress="False"/>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Page>
